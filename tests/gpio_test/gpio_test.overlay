#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
    module_test_gpios {
        compatible = "gpio-leds";

        test_p0_00: test_p0_00 { gpios = <&gpio0 0 GPIO_ACTIVE_HIGH>; label = "P0.00"; };
        test_p0_01: test_p0_01 { gpios = <&gpio0 1 GPIO_ACTIVE_HIGH>; label = "P0.01"; };    
        test_p0_02: test_p0_02 { gpios = <&gpio0 2 GPIO_ACTIVE_HIGH>; label = "P0.02"; };
        test_p0_03: test_p0_03 { gpios = <&gpio0 3 GPIO_ACTIVE_HIGH>; label = "P0.03"; };

        test_p1_02: test_p1_02 { gpios = <&gpio1 2 GPIO_ACTIVE_HIGH>; label = "P1.02"; };
        test_p1_03: test_p1_03 { gpios = <&gpio1 3 GPIO_ACTIVE_HIGH>; label = "P1.03"; };
        test_p1_04: test_p1_04 { gpios = <&gpio1 4 GPIO_ACTIVE_HIGH>; label = "P1.04"; };
        test_p1_05: test_p1_05 { gpios = <&gpio1 5 GPIO_ACTIVE_HIGH>; label = "P1.05"; };
        test_p1_06: test_p1_06 { gpios = <&gpio1 6 GPIO_ACTIVE_HIGH>; label = "P1.06"; };
        
        test_p1_09: test_p1_09 { gpios = <&gpio1 9 GPIO_ACTIVE_HIGH>; label = "P1.09"; };
        test_p1_10: test_p1_10 { gpios = <&gpio1 10 GPIO_ACTIVE_HIGH>; label = "P1.10"; };
        test_p1_11: test_p1_11 { gpios = <&gpio1 11 GPIO_ACTIVE_HIGH>; label = "P1.11"; };
        test_p1_12: test_p1_12 { gpios = <&gpio1 12 GPIO_ACTIVE_HIGH>; label = "P1.12"; };
        test_p1_13: test_p1_13 { gpios = <&gpio1 13 GPIO_ACTIVE_HIGH>; label = "P1.13"; };
        test_p1_14: test_p1_14 { gpios = <&gpio1 14 GPIO_ACTIVE_HIGH>; label = "P1.14"; };

        test_p2_03: test_p2_03 { gpios = <&gpio2 3 GPIO_ACTIVE_HIGH>; label = "P2.03"; };
        test_p2_06: test_p2_06 { gpios = <&gpio2 6 GPIO_ACTIVE_HIGH>; label = "P2.06"; };
        test_p2_07: test_p2_07 { gpios = <&gpio2 7 GPIO_ACTIVE_HIGH>; label = "P2.07"; };
        test_p2_10: test_p2_10 { gpios = <&gpio2 10 GPIO_ACTIVE_HIGH>; label = "P2.10"; };
    };
};


&gpiote20 {status = "okay";};
&gpiote30 {status = "okay";};

&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };
&gpio2 { status = "okay"; };